{
  "name": "@voidrot/pi-ext",
  "version": "0.1.0",
  "type": "module",
  "description": "Single Pi.dev extension package for Voidrot tools and workflow modules.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist/", "README.md", "LICENSE", "config/", "schema/"],
  "keywords": ["pi-package", "pi", "pi-extension", "voidrot"],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "pi": {
    "extensions": ["./dist/index.js"]
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0",
    "typebox": "^1.3.0"
  }
}
