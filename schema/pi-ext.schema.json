{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/voidrot/pi-ext/main/schema/pi-ext.schema.json",
  "title": "Voidrot Pi Extension Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean",
      "description": "Enable or disable all @voidrot/pi-ext modules and owned tools."
    },
    "debug": {
      "type": "boolean",
      "description": "Enable debug logging from @voidrot/pi-ext."
    },
    "dcp": {
      "type": "object",
      "additionalProperties": true,
      "description": "Shorthand for global DCP module config, equivalent to modules.dcp.config. Explicit modules.dcp.config values win when both are set.",
      "properties": {
        "ui": {
          "type": "object",
          "additionalProperties": true,
          "description": "DCP UI surfaces.",
          "properties": {
            "compressedBlocksWidget": {
              "type": "boolean",
              "description": "Show a persistent widget summarizing active compressed context blocks."
            },
            "compressionNotifications": {
              "type": "boolean",
              "description": "Show a toast notification after each compression pass."
            }
          }
        }
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dcp": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Dynamic Context Pruning."
            },
            "tools": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "compress": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the DCP compress tool."
                    }
                  }
                }
              }
            },
            "config": {
              "type": "object",
              "description": "DCP module-specific config. See README for supported keys.",
              "additionalProperties": true,
              "properties": {
                "ui": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "DCP UI surfaces.",
                  "properties": {
                    "compressedBlocksWidget": {
                      "type": "boolean",
                      "description": "Show a persistent widget summarizing active compressed context blocks."
                    },
                    "compressionNotifications": {
                      "type": "boolean",
                      "description": "Show a toast notification after each compression pass."
                    }
                  }
                }
              }
            }
          }
        },
        "dashboard": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable the local Pi Ext dashboard webserver."
            },
            "server": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "host": {
                  "type": "string",
                  "description": "Loopback host to bind the dashboard server to."
                },
                "port": {
                  "description": "Fixed dashboard port or auto to scan the configured range.",
                  "oneOf": [
                    {
                      "const": "auto"
                    },
                    {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    }
                  ]
                },
                "portRange": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "start": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    },
                    "end": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    }
                  }
                }
              }
            },
            "browser": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "openOnStart": {
                  "type": "boolean",
                  "description": "Open the dashboard URL in the system browser when a Pi session starts."
                },
                "reopenOnSessionChange": {
                  "type": "boolean",
                  "description": "Open another dashboard browser tab when Pi session state changes."
                }
              }
            }
          }
        },
        "agents": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable in-process subagents and orchestration tools."
            },
            "orchestrator": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Append default orchestrator instructions to parent sessions."
                }
              }
            },
            "tools": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "runSubagent": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the run_subagent tool."
                    }
                  }
                },
                "getSubagentResult": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the get_subagent_result tool."
                    }
                  }
                },
                "steerSubagent": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the steer_subagent tool."
                    }
                  }
                }
              }
            },
            "maxParallel": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8,
              "description": "Maximum number of parallel foreground/background subagent tasks per tool call."
            },
            "defaultBackground": {
              "type": "boolean",
              "description": "Run subagents in background by default when the tool omits background."
            },
            "childExtensions": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "inherit-safe",
                    "none"
                  ],
                  "description": "Whether child sessions inherit extension loading with recursion guard or disable extensions entirely."
                },
                "recursiveToolDenylist": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Tool names removed from child sessions after extension binding."
                }
              }
            },
            "transcripts": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "persist": {
                  "type": "boolean",
                  "description": "Persist child transcripts under the parent session task directory when possible."
                }
              }
            },
            "stall": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Notify when a child run has no observable activity for timeoutMs."
                },
                "timeoutMs": {
                  "type": "integer",
                  "minimum": 1000,
                  "description": "No-activity interval before marking a child run stalled."
                },
                "notify": {
                  "type": "boolean",
                  "description": "Send a parent follow-up notification when a background child stalls."
                },
                "abortAfterMs": {
                  "type": "integer",
                  "minimum": 1000,
                  "description": "Reserved for future auto-abort after stall."
                }
              }
            }
          }
        }
      }
    }
  }
}
