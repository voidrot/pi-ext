{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/voidrot/pi-ext/main/schema/pi-ext.schema.json",
  "title": "Voidrot Pi Extension Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean",
      "description": "Enable or disable all @voidrot/pi-ext modules and owned tools."
    },
    "debug": {
      "type": "boolean",
      "description": "Enable debug logging from @voidrot/pi-ext."
    },
    "dcp": {
      "type": "object",
      "additionalProperties": true,
      "description": "Shorthand for global DCP module config, equivalent to modules.dcp.config. Explicit modules.dcp.config values win when both are set.",
      "properties": {
        "ui": {
          "type": "object",
          "additionalProperties": true,
          "description": "DCP UI surfaces.",
          "properties": {
            "compressedBlocksWidget": {
              "type": "boolean",
              "description": "Show a persistent widget summarizing active compressed context blocks."
            },
            "compressionNotifications": {
              "type": "boolean",
              "description": "Show a toast notification after each compression pass."
            }
          }
        }
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dcp": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Dynamic Context Pruning."
            },
            "tools": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "compress": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the DCP compress tool."
                    }
                  }
                }
              }
            },
            "config": {
              "type": "object",
              "description": "DCP module-specific config. See README for supported keys.",
              "additionalProperties": true,
              "properties": {
                "compress": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "DCP compression behavior and token budgets.",
                  "properties": {
                    "summaryTiers": {
                      "type": "array",
                      "description": "Age-tier summary budgets. Older content should have lower maxSummaryRatio values.",
                      "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "minTurns": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Minimum DCP turn age for this summary budget tier."
                          },
                          "maxSummaryRatio": {
                            "type": "number",
                            "minimum": 0.01,
                            "maximum": 1,
                            "description": "Maximum summary tokens as a ratio of compressed raw tokens."
                          }
                        }
                      }
                    }
                  }
                },
                "strategies": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "DCP automatic context-retention strategies.",
                  "properties": {
                    "staleToolCalls": {
                      "type": "object",
                      "additionalProperties": true,
                      "description": "Strip old tool-call/tool-result artifacts from outgoing model context.",
                      "properties": {
                        "enabled": {
                          "type": "boolean",
                          "description": "Enable stale tool-call stripping."
                        },
                        "turns": {
                          "type": "integer",
                          "minimum": 1,
                          "description": "Number of DCP turns after which unprotected tool artifacts are stripped."
                        },
                        "protectedTools": {
                          "type": "array",
                          "description": "Tool names exempt from stale tool-call stripping.",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                },
                "ui": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "DCP UI surfaces.",
                  "properties": {
                    "compressedBlocksWidget": {
                      "type": "boolean",
                      "description": "Show a persistent widget summarizing active compressed context blocks."
                    },
                    "compressionNotifications": {
                      "type": "boolean",
                      "description": "Show a toast notification after each compression pass."
                    }
                  }
                }
              }
            }
          }
        },
        "dashboard": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable the local Pi Ext dashboard webserver."
            },
            "server": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "host": {
                  "type": "string",
                  "description": "Loopback host to bind the dashboard server to."
                },
                "port": {
                  "description": "Fixed dashboard port or auto to scan the configured range.",
                  "oneOf": [
                    {
                      "const": "auto"
                    },
                    {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    }
                  ]
                },
                "portRange": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "start": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    },
                    "end": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535
                    }
                  }
                }
              }
            },
            "browser": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "openOnStart": {
                  "type": "boolean",
                  "description": "Open the dashboard URL in the system browser when a Pi session starts."
                },
                "reopenOnSessionChange": {
                  "type": "boolean",
                  "description": "Open another dashboard browser tab when Pi session state changes."
                }
              }
            }
          }
        },
        "agents": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable in-process subagents and orchestration tools."
            },
            "orchestrator": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Append default orchestrator instructions to parent sessions."
                }
              }
            },
            "tools": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "runSubagent": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the run_subagent tool."
                    }
                  }
                },
                "getSubagentResult": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the get_subagent_result tool."
                    }
                  }
                },
                "steerSubagent": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the steer_subagent tool."
                    }
                  }
                }
              }
            },
            "maxParallel": {
              "type": "integer",
              "minimum": 1,
              "maximum": 8,
              "description": "Maximum number of parallel foreground/background subagent tasks per tool call."
            },
            "defaultBackground": {
              "type": "boolean",
              "description": "Run subagents in background by default when the tool omits background."
            },
            "childExtensions": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "inherit-safe",
                    "none"
                  ],
                  "description": "Whether child sessions inherit extension loading with recursion guard or disable extensions entirely."
                },
                "recursiveToolDenylist": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Tool names removed from child sessions after extension binding."
                }
              }
            },
            "transcripts": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "persist": {
                  "type": "boolean",
                  "description": "Persist child transcripts under the parent session task directory when possible."
                }
              }
            },
            "stall": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Notify when a child run has no observable activity for timeoutMs."
                },
                "timeoutMs": {
                  "type": "integer",
                  "minimum": 1000,
                  "description": "No-activity interval before marking a child run stalled."
                },
                "notify": {
                  "type": "boolean",
                  "description": "Send a parent follow-up notification when a background child stalls."
                },
                "abortAfterMs": {
                  "type": "integer",
                  "minimum": 1000,
                  "description": "Reserved for future auto-abort after stall."
                }
              }
            }
          }
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable memory tools and prompt context."
            },
            "prompt": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Inject saved memories into new session system prompts."
                },
                "maxMemoriesPerScope": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 100,
                  "description": "Maximum memories to inject for each scope."
                },
                "maxContentChars": {
                  "type": "integer",
                  "minimum": 80,
                  "maximum": 4000,
                  "description": "Maximum characters per memory in prompt context."
                }
              }
            },
            "tools": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "createGlobalMemory": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the create_global_memory tool."
                    }
                  }
                },
                "createProjectMemory": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the create_project_memory tool."
                    }
                  }
                },
                "createSessionMemory": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the create_session_memory tool."
                    }
                  }
                },
                "searchMemories": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Expose and activate the search_memories tool."
                    }
                  }
                }
              }
            },
            "vector": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "description": "Enable sqlite-vec backed vector indexing and search for memories."
                },
                "provider": {
                  "type": "string",
                  "enum": ["local", "ollama"],
                  "description": "Embedding provider used for memory vector indexing and search."
                },
                "dimensions": {
                  "type": "integer",
                  "const": 256,
                  "description": "Embedding dimensions. Existing sqlite-vec tables are fixed at 256 dimensions."
                },
                "searchLimit": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 50,
                  "description": "Default number of vector memory search results."
                },
                "background": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Create/update memory vectors asynchronously after memory tools return."
                    },
                    "batchSize": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 100,
                      "description": "Maximum pending memories to index per background worker pass."
                    }
                  }
                },
                "ollama": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "endpoint": {
                      "type": "string",
                      "description": "Base Ollama endpoint, for example http://127.0.0.1:11434."
                    },
                    "model": {
                      "type": "string",
                      "description": "Ollama embedding model, for example nomic-embed-text."
                    },
                    "timeoutMs": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Ollama embedding request timeout in milliseconds."
                    },
                    "keepAlive": {
                      "type": "string",
                      "description": "Optional Ollama keep_alive value."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
